# ==============================================================================
# GebzemDugun.com — Environment Variables
# Bu dosyayı `.env` olarak kopyalayın ve gerçek değerlerle doldurun.
# Vercel'de aynı değerleri Project Settings → Environment Variables'a ekleyin.
# ==============================================================================

# --- Public ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="GebzemDugun"

# ==============================================================================
# SUPABASE — TAM ENTEGRASYON
# ==============================================================================
# Supabase Dashboard > Project Settings > API'den alın:
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbG..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbG..."

# Supabase Dashboard > Project Settings > Database > Connection String:
#  - Pooled (uygulama runtime'ı için, port 6543, pgbouncer):
DATABASE_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#  - Direct (Prisma migrate ve introspect için, port 5432):
DIRECT_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ==============================================================================
# AUTH (NextAuth v5)
# ==============================================================================
# `openssl rand -base64 32` veya `npx auth secret` ile oluşturun
AUTH_SECRET="change-me-strong-random-string-min-32-chars"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# OAuth Providers (opsiyonel)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ==============================================================================
# E-POSTA & SMS
# ==============================================================================
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@gebzemdugun.com"
NETGSM_USERCODE=""
NETGSM_PASSWORD=""
NETGSM_HEADER="GEBZEM"

# ==============================================================================
# ÖDEME (iyzico — sandbox ile başla)
# ==============================================================================
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# ==============================================================================
# DİĞER (opsiyonel)
# ==============================================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"
SENTRY_DSN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_TOKEN=""
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
